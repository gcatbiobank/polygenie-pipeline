// Control parallelism for local execution. Increase `maxForks` to allow more
// concurrent process tasks (e.g. many PRS percentiles computed in parallel).
// Adjust this to match available CPU cores or cluster scheduler settings.
process {
    executor = 'local'
    // Maximum number of concurrent tasks Nextflow will run
    maxForks = 8
    cpus = 1
    //beforeScript = 'export PATH=/imppc/labs/dnalab/xfarrer/miniforge3/bin:$PATH'
}

// Profile for SGE/UGE/OGE cluster execution. Use with `-profile sge` when
// running on a cluster that uses Sun Grid Engine or compatible schedulers.
profiles {
    sge {
        // Allow passing SGE-specific params via params.sge in the pipeline config
        params.sge = params.sge ?: [:]

        process {
            executor = 'sge'
            // Default queue - override with params.sge.queue when launching
            queue = params.sge.queue ?: 'all.q'
            // Map Nextflow task.cpus to the SGE parallel environment. Ensure the
            // parallel environment (default 'smp') exists on your cluster.
            // You can override the PE name with params.sge.parallel_env.
            clusterOptions = "-pe ${params.sge.parallel_env ?: 'smp'} 4"
            // Optional: request a default walltime (can be overridden per-process)
            // clusterOptions += " -l h_rt=${params.sge.walltime ?: '04:00:00'}"
            // Let the cluster scheduler handle parallelism (do not limit maxForks)
        }
    }

    gpu {
        // GPU-enabled SGE profile. Use with `-profile gpu`.
        params.gpu = params.gpu ?: [:]
        process {
            executor = 'sge'
            queue = params.gpu.queue ?: 'gpu.q'
            clusterOptions = "-l gpu=${params.gpu.gpu ?: 1}"
            // Optionally add walltime, memory, etc. as needed
        }
    }
}
